# Laravel API 服務（Zeabur Root Directory: / 留空或 .）
APP_NAME=冷氣清洗派班系統
APP_ENV=production
APP_DEBUG=false
APP_URL=
APP_TIMEZONE=Asia/Taipei

# 於 Zeabur 控制台綁定 MySQL 後注入，勿寫入 Git
DATABASE_URL=

ZBPACK_PHP_OPTIMIZE=true
# 必須設定為前端實際網域
CORS_ALLOWED_ORIGINS=
SANCTUM_EXPIRATION=480
LOG_LEVEL=warning

# 於 Zeabur 控制台產生後設定
APP_KEY=

# 首次部署後，於 Zeabur 服務終端機執行（建立管理員帳號）：
# php artisan migrate --force
# php artisan admin:ensure 邱泰翔 z34178900 --name=阿泰
