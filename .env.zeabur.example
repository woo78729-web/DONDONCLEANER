# Laravel API 服務（Zeabur Root Directory: / 留空或 .）
APP_NAME=冷氣清洗派班系統
APP_ENV=production
APP_DEBUG=false
APP_URL=https://你的-laravel-api.zeabur.app
APP_TIMEZONE=Asia/Taipei

# 在 Zeabur 綁定 MySQL 後自動注入，或手動貼上
DATABASE_URL=mysql://user:password@host:3306/database

ZBPACK_PHP_OPTIMIZE=true
CORS_ALLOWED_ORIGINS=https://你的-react-frontend.zeabur.app

# Laravel 會自動從 APP_KEY 產生，部署前執行：php artisan key:generate --show
APP_KEY=
