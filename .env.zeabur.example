# Laravel API 服務（Zeabur Root Directory: / 留空或 .）
APP_NAME=東東冷氣專業清洗
APP_ENV=production
APP_DEBUG=false
APP_URL=
APP_TIMEZONE=Asia/Taipei

# 於 Zeabur 控制台綁定 MySQL 後注入，勿寫入 Git
DATABASE_URL=

ZBPACK_PHP_OPTIMIZE=true
# 必須設定為前端實際網域
CORS_ALLOWED_ORIGINS=
SANCTUM_EXPIRATION=480
LOG_LEVEL=warning

# 於 Zeabur 控制台產生後設定
APP_KEY=

# 首次部署後，於 Zeabur Laravel 服務「指令 / Terminal」執行：
#   composer run-script deploy
# 或：
#   php artisan migrate --force && php artisan storage:link --force
# 或（本機連遠端 DB）：
#   .\scripts\zeabur-migrate.ps1
#
# 建立管理員：
# php artisan admin:ensure 邱泰翔 z34178900 --name=阿泰
